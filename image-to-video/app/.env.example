# ── EAU DE SILK 캐릭터 광고 스튜디오 환경변수 ──
# 이 파일을 복사해서 .env 로 저장하고 값을 채우세요.  cp .env.example .env
#
# 키가 없어도 앱은 '목업 모드'로 끝까지 동작합니다(플레이스홀더 이미지/클립).
# 키를 넣으면 해당 단계가 실제 생성으로 바뀝니다.

# [PLAN] Claude 스토리 기획 (없으면 기본 아크 목업 사용)
ANTHROPIC_API_KEY=

# 사용할 Claude 모델 (기본: claude-opus-4-8)
# CLAUDE_MODEL=claude-opus-4-8

# [IMAGE/VIDEO] 힉스필드 생성 (없으면 목업 — 현재는 세션의 힉스필드 MCP로 실제 생성)
HIGGSFIELD_API_KEY=

# 서버 바인딩
HOST=0.0.0.0
PORT=8000
